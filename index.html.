DOCTYPE html>
<html>
<head>
    <title>Happy Birthday 🎉</title>
    <style>
        body {
            background: #0d0d0d;
            color: white;
            font-family: Arial;
            text-align: center;
            padding: 20px;
        }
        input, button {
            padding: 10px;
            margin: 5px;
        }
    </style>
</head>

<body>

<h1>🎉 Happy Birthday 🎉</h1>

<p>
Hey… I made this just for you.<br><br>
I really enjoy talking to you.<br>
Hope your day is special 💜
</p>

<hr>

<h2>🎮 Guess My Number</h2>
<p>1–100 | 10 attempts | 3 hints</p>

<input type="number" id="guess">
<button onclick="check()">Guess</button>
<button onclick="hint()">Hint</button>

<p id="result"></p>
<p id="attempts">Attempts: 0 / 10</p>
<p id="hints">Hints left: 3</p>

<script>
let number = 47;
let tries = 0;
let hintsLeft = 3;

function check() {
    if (tries >= 10) return;

    let guess = document.getElementById("guess").value;
    tries++;

    if (guess == number) {
        document.getElementById("result").innerHTML = "🎉 You win!";
    } 
    else if (tries >= 10) {
        document.getElementById("result").innerHTML = "💀 Game Over!";
    }
    else if (guess > number) {
        document.getElementById("result").innerHTML = "Too high!";
    } 
    else {
        document.getElementById("result").innerHTML = "Too low!";
    }

    document.getElementById("attempts").innerHTML = "Attempts: " + tries + " / 10";
}

function hint() {
    if (hintsLeft <= 0) return;

    hintsLeft--;

    let msg = "";

    if (hintsLeft == 2) {
        msg = (number % 2 == 0) ? "EVEN" : "ODD";
    } else if (hintsLeft == 1) {
        msg = number > 50 ? "Greater than 50" : "50 or less";
    } else {
        msg = "Between " + (number-5) + " and " + (number+5);
    }

    document.getElementById("result").innerHTML = "💡 " + msg;
    document.getElementById("hints").innerHTML = "Hints left: " + hintsLeft;
}
</script>

</body>
</html>
